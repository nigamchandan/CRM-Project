# =============================================================================
#  Environment file used by docker-compose.yml and docker-compose.prod.yml
#  Copy to .env and fill in real values BEFORE running `docker compose up`.
#  This file MUST NOT be committed (already gitignored).
# =============================================================================

# ---------- Database ----------
DB_NAME=crm_db
DB_USER=crm_user
DB_PASSWORD=change_me_strong_password

# ---------- App / JWT ----------
JWT_SECRET=replace_with_long_random_string
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:8080
MAX_UPLOAD_MB=10

# Set to true ONLY on first deploy to populate demo/seed data.
# After the first successful run, change back to false to avoid duplicate seeds.
RUN_DB_SEED=false

# ---------- Public HTTP port on the host (EC2 = 80, local dev = 8080) ----------
HOST_HTTP_PORT=8080

# ---------- SMTP (leave SMTP_HOST blank to log emails to console) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=CRM Support <no-reply@crm.test>

# ---------- Production-only: GHCR image pulling ----------
# Leave these unset for local; the prod compose file uses them.
GHCR_OWNER=nigamchandan
IMAGE_TAG=latest
