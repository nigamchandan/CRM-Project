# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_db
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=super_secret_change_me
JWT_EXPIRES_IN=7d

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10

# Email / SMTP (optional — leave SMTP_HOST blank to run in dry-run mode,
# in which case emails are logged to the server console instead of being sent.)
# Example for Gmail App Password:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your-account@gmail.com
#   SMTP_PASS=your-app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=CRM Support <no-reply@crm.test>
